# Supabase - https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Solo servidor: API /api/availability (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Para Magic Link y callbacks (producción)
NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app

# Resend - API key para envío de emails
# También configurar en Supabase: Auth > SMTP Settings (Host: smtp.resend.com, Port: 465, User: resend, Password: esta key)
RESEND_API_KEY=your_resend_api_key
